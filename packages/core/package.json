{
  "name": "@pdfx/core",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./extract": {
      "types": "./dist/extract/index.d.ts",
      "default": "./dist/extract/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "vitest run"
  },
  "dependencies": {
    "@napi-rs/canvas": "0.1.100",
    "@tesseract.js-data/eng": "1.0.0",
    "pdf-lib": "1.17.1",
    "pdfjs-dist": "5.7.284",
    "tesseract.js": "7.0.0"
  },
  "devDependencies": {
    "@types/node": "22.19.21",
    "typescript": "5.9.3",
    "vitest": "3.2.4"
  }
}
